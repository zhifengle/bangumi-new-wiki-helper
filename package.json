{
  "name": "bangumi-new-wiki-helper",
  "version": "0.5.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "sync:version": "node bin/sync-version.js",
    "prebuild": "npm run sync:version",
    "build": "web-ext build -s extension",
    "build:script": "rollup -c build/rollup.config.us.mjs",
    "build:ext": "rollup -c build/rollup.config.ext.mjs",
    "dev:ext": "rollup -w -c build/rollup.config.ext.mjs",
    "dev:test": "rollup -w -c build/rollup.config.dev.mjs",
    "clean": "rimraf dist/ extension/dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:e2e:live": "playwright test --config playwright.live.config.ts"
  },
  "author": "zhifengle",
  "license": "MPL-2.0",
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@types/firefox-webext-browser": "120.0.4",
    "@types/webextension-polyfill": "0.12.3",
    "fast-check": "4.6.0",
    "jsdom": "29.0.2",
    "rollup": "4.60.1",
    "rollup-plugin-typescript2": "0.37.0",
    "ts-loader": "^9.2.3",
    "ts-node": "^10.9.0",
    "typescript": "^5.9.0",
    "vite": "8.0.8",
    "vitest": "4.1.3",
    "web-ext": "^8.9.0",
    "webextension-polyfill": "0.12.0"
  },
  "dependencies": {
    "notyf": "^3.10.0",
    "stackblur-canvas": "2.2.0"
  }
}
